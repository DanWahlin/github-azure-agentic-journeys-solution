# Base URL for the AIMarket API, including the /api suffix.
# In local dev you can leave this unset to use the Vite dev proxy (/api -> API server).
# In production set it to the full API base, e.g.:
#   VITE_API_URL=https://ca-api-xxxx.azurecontainerapps.io/api
# VITE_API_URL=

# Dev/preview proxy target (only used when VITE_API_URL is not set).
# Point this at wherever the API is listening; the port is NOT hardcoded here.
# VITE_API_PROXY_TARGET=http://localhost:3000
