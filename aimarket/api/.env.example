# AIMarket API configuration

# Preferred local port. If busy, the server auto-selects the next free port
# (it will not kill the process using PORT).
PORT=3000

# Data provider: sqlite (default) | cosmos | postgres
DATA_PROVIDER=sqlite

# SQLite database file path (relative to api/)
SQLITE_DB_PATH=aimarket.db

# --- AI features (Phase 3+, optional locally) ---
# When unset: semantic search falls back to SQLite LIKE queries and /api/chat
# returns 503. Phase 4 provisions Azure AI Search + Microsoft Foundry and wires
# these values into Container Apps (Foundry via managed identity, no key).
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_KEY=
# AZURE_SEARCH_INDEX=aimarket-products
# AZURE_SEARCH_SEMANTIC_CONFIG=aimarket-semantic
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# AZURE_OPENAI_API_VERSION=2024-10-21
